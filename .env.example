NEXT_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=694ed12f003c942317f4
NEXT_PUBLIC_APPWRITE_DATABASE_ID=peerspark-main-db

# Legacy aliases kept for older API routes/scripts. Keep these in sync with NEXT_PUBLIC_APPWRITE_DATABASE_ID.
NEXT_PUBLIC_DATABASE_ID=peerspark-main-db
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=694ed12f003c942317f4
APPWRITE_DATABASE_ID=peerspark-main-db

# Appwrite collection IDs used by API routes. Defaults match scripts/update-schema.js.
NEXT_PUBLIC_PROFILES_COLLECTION_ID=profiles
NEXT_PUBLIC_POSTS_COLLECTION_ID=posts
NEXT_PUBLIC_COMMENTS_COLLECTION_ID=comments
NEXT_PUBLIC_MESSAGES_COLLECTION_ID=messages
NEXT_PUBLIC_RESOURCES_COLLECTION_ID=resources
NEXT_PUBLIC_NOTIFICATIONS_COLLECTION_ID=notifications
NEXT_PUBLIC_PODS_COLLECTION_ID=pods
NEXT_PUBLIC_CALENDAR_EVENTS_COLLECTION_ID=calendar_events
NEXT_PUBLIC_CHAT_ROOMS_COLLECTION_ID=chat_rooms
NEXT_PUBLIC_SAVED_POSTS_COLLECTION_ID=saved_posts
NEXT_PUBLIC_COURSES_COLLECTION_ID=courses
NEXT_PUBLIC_CHAPTERS_COLLECTION_ID=course_chapters

# Appwrite storage bucket IDs used by uploads.
NEXT_PUBLIC_AVATARS_BUCKET_ID=avatars
NEXT_PUBLIC_RESOURCES_BUCKET_ID=resources
NEXT_PUBLIC_ATTACHMENTS_BUCKET_ID=attachments
NEXT_PUBLIC_POST_IMAGES_BUCKET_ID=post_images
NEXT_PUBLIC_POD_IMAGES_BUCKET_ID=pod_images

# Never commit real API keys. Put the real value only in .env.local or your deployment secret store.
APPWRITE_API_KEY=replace-with-your-appwrite-server-api-key
NEXT_PUBLIC_ENABLE_APPWRITE_DEBUG=false
